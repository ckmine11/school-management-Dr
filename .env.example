# Copy this file to .env and fill in your values
# Used by docker-compose.yml

# ─── Server ───────────────────────────────────────────
BACKEND_PORT=5000
FRONTEND_PORT=80

# ─── Security (CHANGE THESE — do NOT use the example values in production) ───
JWT_SECRET=replace_with_64_char_random_hex_string
JWT_EXPIRE=7d
ADMIN_RECOVERY_SECRET=ReplaceWithSomethingSecretOnlyYouKnow

# ─── School Info ──────────────────────────────────────
SCHOOL_NAME=Bright Future School
SCHOOL_EMAIL=admin@brightfutureschool.com

# ─── Frontend URL (used for CORS) ────────────────────
FRONTEND_URL=http://localhost

# ─── OneSignal Push Notifications (free) — get from app.onesignal.com ───
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key
